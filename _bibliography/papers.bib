  booktitle={IEEE International Conference on Communications (ICC)},
  year={2025},
  publisher={IEEE},
  abstract={UAV-based base stations offer a promising solution in emergencies where the rapid deployment of cutting-edge networks is crucial for maximizing life-saving potential. This paper introduces an automated reinforcement learning approach that enables UAVs to dynamically interact with their environment and determine optimal configurations. Leveraging radio signal sensing capabilities of communication networks, we utilize the proximal policy optimization algorithm to learn and generalize positioning strategies across diverse user equipment movement patterns.},
